{
  "name": "proxy-live-document",
  "version": "3.0.0",
  "type": "module",
  "description": "Mutable, observable, patchable JSON state wrapped in Smart Domains",
  "types": "dist/index.d.ts",
  "main": "dist/index.main.js",
  "module": "dist/index.module.js",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && rollup -c",
    "test": "vitest --config ./vitest/vitest.config.ts run",
    "test:watch": "vitest --config ./vitest/vitest.config.ts watch",
    "test:coverage": "vitest --config ./vitest/vitest.config.ts run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vladnicula/proxy-live-document"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^29.5.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/minimatch": "^5.1.2",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.0",
    "husky": "^9.1.7",
    "jest": "^29.3.1",
    "lint-staged": "^16.2.6",
    "lodash.merge": "^4.6.2",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^4.0.6"
  },
  "keywords": [
    "state-managment",
    "realtime-updates"
  ],
  "lint-staged": {
    "*.ts": [
      "eslint --fix --max-warnings=-1"
    ]
  },
  "dependencies": {
    "@vitest/coverage-istanbul": "^4.0.6"
  }
}
